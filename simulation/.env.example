# ─── Dynamic-Fee-AMM Phase 5 — Relayer Environment ───────────────────────────
#
# Copy this file to simulation/.env and fill in real values.
# NEVER commit the populated .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# EVM JSON-RPC endpoint. Any standard provider works (Alchemy, Infura, Ankr, etc.)
# Testnet example: https://rpc.ankr.com/eth_sepolia
RPC_URL=https://rpc.ankr.com/eth_sepolia

# Hex private key of the wallet that was baked in as poolAdmin at factory deploy time.
# This key must match the address that deployed PoolFactory (i.e. the factory owner).
# Must start with 0x.
RELAYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Checksum or lowercase address of the DynamicFeePool you want to update.
POOL_CONTRACT_ADDRESS=0xYOUR_POOL_ADDRESS_HERE

# Set to "true" to execute the full scoring pipeline without broadcasting a transaction.
# Useful for local validation, CI, and cost-free smoke tests.
DRY_RUN=true
