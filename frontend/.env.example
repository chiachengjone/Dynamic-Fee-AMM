# ─── Dynamic-Fee-AMM Dashboard — Frontend Environment ────────────────────────
#
# Copy to frontend/.env to connect the dashboard to a live chain.
# If EITHER value is missing, the dashboard runs in self-contained SANDBOX mode
# (full simulation, no node required) — perfect for local UI verification.
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# JSON-RPC endpoint to poll. For a local Foundry node: http://127.0.0.1:8545
VITE_RPC_URL=http://127.0.0.1:8545

# Address of the deployed DynamicFeePool to mirror on the dashboard.
VITE_POOL_ADDRESS=0xYOUR_POOL_ADDRESS_HERE

# Chain ID the dashboard expects wallets to be on for live swaps.
# 11155111 = Sepolia (default). Used to detect/switch network in MetaMask.
VITE_CHAIN_ID=11155111

# Address of the deployed PoolFactory contract.
# Used to look up the pool address for any base/quote token pair dynamically
# (calls PoolFactory.getPool(tokenA, tokenB)). Without this, live mode falls
# back to sandbox with a descriptive message.
VITE_FACTORY_ADDRESS=0xYOUR_FACTORY_ADDRESS_HERE

# Optional: how often (ms) to re-poll on-chain state in live mode. Default 8000.
VITE_POLL_INTERVAL_MS=8000

# Pipeline feed — macro_pipeline.py --serve
# Base URL of the local pipeline API server (no trailing slash).
VITE_PIPELINE_URL=http://localhost:8765
# How often the dashboard polls the pipeline server in ms. Default 15000.
VITE_PIPELINE_POLL_MS=15000
