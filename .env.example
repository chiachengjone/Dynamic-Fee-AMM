# ─── Dynamic-Fee-AMM — Deployment Credentials ────────────────────────────────
#
# Copy to .env and fill in real values before running the deploy script.
# NEVER commit .env to git — it is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Private key of the deployer wallet (hex, with or without 0x prefix).
# Use a fresh throwaway wallet — never your main MetaMask account.
# Fund it with ~0.05 Sepolia ETH from a faucet before deploying.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Alchemy (or Infura) Sepolia RPC endpoint.
# Free tier at https://alchemy.com is sufficient.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Etherscan API key for contract verification (optional but recommended).
# Free at https://etherscan.io/myapikey — makes source code public on Sepolia.
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
